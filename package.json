{
  "name": "orz-coursewerk",
  "version": "0.10.1",
  "private": true,
  "type": "module",
  "description": "Agent-native harness that builds a complete, Alembic-ready OER course package from source materials, natively using the orz-markdown family (orz-mdhtml / orz-slides / orz-paged).",
  "license": "MIT",
  "bin": {
    "coursewerk-check": "scripts/check_oer.mjs"
  },
  "scripts": {
    "check": "node scripts/check_oer.mjs --package package",
    "check:assurance": "node scripts/check_assurance.mjs --root personal",
    "generate:attribution": "node scripts/generate_attribution.mjs --root package",
    "prepare:source": "node scripts/prepare_source_corpus.mjs",
    "prepare:wikipedia-topic": "node scripts/prepare_wikipedia_topic.mjs",
    "capture:rights": "node scripts/capture_rights_evidence.mjs",
    "init:output-git": "node scripts/init_output_git.mjs --root package",
    "index:components": "node scripts/index_components.mjs --root package --initialize",
    "revision:impact": "node scripts/revision_impact.mjs --root package",
    "system:index": "node scripts/index_coursewerk.mjs",
    "system:impact": "node scripts/coursewerk_impact.mjs",
    "system:verify": "node scripts/verify_coursewerk.mjs",
    "system:accept": "node scripts/accept_coursewerk_revision.mjs",
    "build:carriers": "node scripts/build_carriers.mjs --package package --out preview",
    "pack": "node scripts/pack.mjs --package package --out dist",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "orz-mdhtml": "^0.9.0",
    "orz-slides": "^0.8.0",
    "orz-paged": "^0.7.0",
    "orz-markdown": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
