  "knownFindings": [
    {
      "id": "AUDIT-A11Y-001",
      "severity": "P1",
      "status": "resolved",
      "summary": "Some accessibility-floor findings do not block release.",
      "resolution": "Alt text, diagram/chart text alternatives, heading starts/jumps/empties, and descriptive links are release-blocking; post-render behavior remains explicitly human-reviewed."
    },
    {
      "id": "AUDIT-AUTHORSHIP-001",
      "severity": "P1",
      "status": "resolved",
      "summary": "Public output and original assets can identify an AI agent instead of an accountable rights holder.",
      "resolution": "Public foundations require a named non-AI author/rightsholder and self-generated/user-owned creators must match an accountable author."
    },
    {
      "id": "AUDIT-CARRIER-EVIDENCE-001",
      "severity": "P1",
      "status": "resolved",
      "summary": "Static carrier shells report a misleading zero rendered-image accessibility count.",
      "resolution": "Receipts now label source and static-shell inspections precisely and require a separate runtime visual review instead of claiming rendered coverage."
    },
    {
      "id": "AUDIT-CARRIER-PORTABILITY-001",
      "severity": "P1",
      "status": "resolved",
      "summary": "Media-bearing carriers are described as self-contained although local assets remain external.",
      "resolution": "Receipts classify single-file versus carrier-plus-assets modes, expose dependencies, and support strict --require-single-file enforcement; product wording was corrected."
    },
    {
      "id": "AUDIT-CARRIER-RECEIPT-001",
      "severity": "P2",
      "status": "resolved",
      "summary": "The carrier receipt hash cannot be reproduced because the exact receipt is not delivered.",
      "resolution": "Packing persists and hash-binds the canonical .carriers.json beside the release receipt."
    },
    {
      "id": "AUDIT-DIAGRAM-A11Y-001",
      "severity": "P1",
      "status": "resolved",
      "summary": "Runtime Mermaid/chart meaning can disappear offline without a visible alternative.",
      "resolution": "Public QA requires a substantive adjacent Visual description or Data summary for every Mermaid/chart block."
    },
    {
      "id": "AUDIT-FORMAT-001",
      "severity": "P1",
      "status": "resolved",
      "summary": "Deliverable format checks are incomplete.",
      "resolution": "Chapter skeleton, objective propagation, slide templates, assessment sections, and practice counts are validated."
    },
    {
      "id": "AUDIT-INDEX-001",
      "severity": "P0",
      "status": "resolved",
      "summary": "Content and component index can be replaced together.",
      "resolution": "An external accepted-state ledger anchors the accepted component-index hash."
    },
    {
      "id": "AUDIT-LICENSE-001",
      "severity": "P0",
      "status": "resolved",
      "summary": "General rights evidence and license text are only weakly asserted.",
      "resolution": "Hashed local evidence snapshots and exact official legal-text hashes are required."
    },
    {
      "id": "AUDIT-MEDIA-001",
      "severity": "P0",
      "status": "resolved",
      "summary": "Remote media can bypass provenance.",
      "resolution": "Markdown and HTML remote media are release-blocking; local assets require structured provenance."
    },
    {
      "id": "AUDIT-MEDIA-PLAN-001",
      "severity": "P2",
      "status": "resolved",
      "summary": "A chapter can silently omit the real-photo expectation in Coursewerk authoring guidance.",
      "resolution": "Each chapter either includes a rights-cleared photo or records a substantive accountable not-used decision in MEDIA_PLAN.json."
    },
    {
      "id": "AUDIT-ORZ-001",
      "severity": "P1",
      "status": "resolved",
      "summary": "Regex syntax checks miss plugins and invalid nesting.",
      "resolution": "The real parser runs and generic plugin balance plus nested fence direction are enforced."
    },
    {
      "id": "AUDIT-PAGED-001",
      "severity": "P1",
      "status": "resolved",
      "summary": "Paged source routing conflicts with the package contract.",
      "resolution": "DOCUMENTS.json declares carrier type for sources in valid public/private/personal paths."
    },
    {
      "id": "AUDIT-PROCESS-RIGHTS-001",
      "severity": "P0",
      "status": "resolved",
      "summary": "A process-specific generative-AI ingestion notice can be present while the AI workflow and release gate continue.",
